{
  "expo": {
    "name": "BharkhaDevi Ice Cream",
    "slug": "bharkhadevi-icecream",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bharkhadevi",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFD600"
    },
    "android": {
      "package": "com.kuldeep2002.bharkahadevi",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFD600"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kuldeep2002.bharkahadevi",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location for delivery."
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow BharkhaDevi to use your location for delivery."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0912ed82-6b16-4aaa-8b69-74996bcd8171"
      }
    },
    "owner": "kuldeep2002"
  }
}